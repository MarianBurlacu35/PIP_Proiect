package proiectpip;

import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.exc.MismatchedInputException;
import java.io.IOException;

public class TestPIP {
    private static final String API_KEY = "sk-9270b33b251b4488b46a61dd2871dcb6";
    private static final String BASE_URL = "https://api.deepseek.com/v1"; // fixed typo: "deeepseek" -> "deepseek"

    public static void main(String[] args) throws IOException, InterruptedException {
        String body = """
            {
                "model": "deepseek-reasoner",
                "messages": [
                    {
                        "role": "user",
                        "content": "How many r's are in the word Strawberry"
                    }
                ]
            }
        """;

        HttpRequest request = HttpRequest.newBuilder()
                .uri(URI.create(BASE_URL + "/chat/completions"))
                .header("Content-Type", "application/json")
                .header("Authorization", "Bearer " + API_KEY)
                .POST(HttpRequest.BodyPublishers.ofString(body))
                .build();

        HttpClient client = HttpClient.newHttpClient();
        HttpResponse<String> response = client.send(request, HttpResponse.BodyHandlers.ofString());

        int statusCode = response.statusCode();
        String responseBody = response.body();

        System.out.println("Status code: " + statusCode);
        System.out.println("Raw response:\n" + responseBody);

        if (statusCode == 200 && responseBody != null && !responseBody.isBlank()) {
            try {
                ObjectMapper mapper = new ObjectMapper();
                Object json = mapper.readValue(responseBody, Object.class);
                String prettyJson = mapper.writerWithDefaultPrettyPrinter().writeValueAsString(json);
                System.out.println("Parsed response:\n" + prettyJson);
            } catch (MismatchedInputException e) {
                System.err.println("Failed to parse JSON: Response was empty or invalid.");
            }
        } else {
            System.err.println("Request failed or response is empty.");
        }
    }
}
